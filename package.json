{
  "name": "bookrag",
  "version": "0.0.1",
  "description": "Browser extension for local intelligent reading of serial fiction. WebGPU + WebLLM, no external APIs.",
  "private": true,
  "type": "module",
  "scripts": {
    "precompile-schema": "node scripts/precompile-schema.mjs",
    "predev": "npm run precompile-schema",
    "prebuild": "npm run precompile-schema",
    "pretest": "npm run precompile-schema",
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.79",
    "@mozilla/readability": "^0.5.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "idb": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.0.280",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
